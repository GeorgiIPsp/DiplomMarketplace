@page "/profile"
@using Marketplace.Models
@using yyy.Services
@inject IOrderService OrderService
@inject IProductService ProductService
@inject UserService UserService
@inject IJSRuntime JSRuntime
@inject NavigationManager NavigationManager
@rendermode InteractiveServer
<link href="css/pr.css" rel="stylesheet" />

<nav class="top-nav">
    <div class="nav-container">
        <div class="nav-brand">VALUED</div>
        <div class="search-container" style="margin: auto">
            
        </div>
        <ul class="nav-menu" style="margin-left: auto;">
            <li><a href="/" class="nav-link active">Главная</a></li>
           
        </ul>
    </div>
</nav>
@if (isLoading)
{
    <div class="loading">Загрузка истории заказов...</div>
}
else if (hasError)
{
    <div class="error">
        <p>Ошибка при загрузке истории заказов</p>
        <button @onclick="RetryLoading" class="retry-btn">Попробовать снова</button>
    </div>
}
else
{
    <div class="profile-container">
        <div class="profile-header">
            <h1>Мой профиль</h1>
            <div class="user-info">
                <p><strong>Email:</strong> @(UserService.currentUser?.Email ?? "Не указан")</p>
                <p><strong>Имя:</strong> @(UserService.currentUser?.FirstName ?? "") @(UserService.currentUser?.LastName ?? "")</p>
                <p><strong>Телефон:</strong> @(UserService.currentUser?.Phone ?? "Не указан")</p>
            </div>
            <button class="logout-btn" @onclick="Logout">Выйти из аккаунта</button>
        </div>

        <div class="orders-tabs">
            <button class="tab-btn @(activeTab == "current" ? "active" : "")" @onclick='() => SwitchTab("current")'>
                Текущие заказы (@currentOrders.Count)
            </button>
            <button class="tab-btn @(activeTab == "completed" ? "active" : "")" @onclick='() => SwitchTab("completed")'>
                История заказов (@completedOrders.Count)
            </button>
        </div>

        @if (activeTab == "current")
        {
            <div class="orders-grid">
                @if (currentOrders.Any())
                {
                    @foreach (var order in currentOrders)
                    {
                        <div class="order-card">
                            <div class="order-status status-@GetStatusClass(order.Status)">
                                @order.Status
                                @if (order.StatusDate.HasValue)
                                {
                                    <span class="status-date">(@order.StatusDate.Value.ToString("dd.MM.yyyy HH:mm"))</span>
                                }
                            </div>
                            <div class="order-number">Заказ #@order.OrderId</div>
                            <div class="order-date">@order.OrderDate.ToString("dd.MM.yyyy HH:mm")</div>

                            <div class="order-items">
                                @for (int i = 0; i < order.Products.Count; i++)
                                {
                                    <div class="order-item">
                                        <div class="item-name">@order.Products[i].Name</div>
                                        <div class="item-quantity">@order.Quantities[i] шт.</div>
                                        <div class="item-price">
                                            @{
                                                if (decimal.TryParse(order.Products[i].Price, out decimal price))
                                                {
                                                    @((price * order.Quantities[i]).ToString("N2"))
                                                }
                                                else
                                                {
                                                    @("0.00")
                                                }
                                            }
                     руб.
                                        </div>
                                    </div>
                                }
                            </div>

                            <div class="order-total">Итого: @order.TotalAmount.ToString("N2") руб.</div>

                            <div class="order-actions">
                                @if (order.Status == "Создан" || order.Status == "Подтвержден")
                                {
                                    <button class="cancel-btn" @onclick="() => CancelOrder(order.OrderId)">Отменить заказ</button>
                                }
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="empty-state">
                        <p>У вас нет активных заказов</p>
                        <button class="continue-shopping-btn" @onclick="ContinueShopping">Продолжить покупки</button>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="orders-grid">
                @if (completedOrders.Any())
                {
                    @foreach (var order in completedOrders)
                    {
                        <div class="order-card">
                            <div class="order-status status-@GetStatusClass(order.Status)">
                                @order.Status
                                @if (order.StatusDate.HasValue)
                                {
                                    <span class="status-date">(@order.StatusDate.Value.ToString("dd.MM.yyyy HH:mm"))</span>
                                }
                            </div>
                            <div class="order-number">Заказ #@order.OrderId</div>
                            <div class="order-date">@order.OrderDate.ToString("dd.MM.yyyy HH:mm")</div>

                            <div class="order-items">
                                @for (int i = 0; i < order.Products.Count; i++)
                                {
                                    <div class="order-item">
                                        <div class="item-name">@order.Products[i].Name</div>
                                        <div class="item-quantity">@order.Quantities[i] шт.</div>
                                        <div class="item-price">
                                            @{
                                                if (decimal.TryParse(order.Products[i].Price, out decimal price))
                                                {
                                                    @((price * order.Quantities[i]).ToString("N2"))
                                                }
                                                else
                                                {
                                                    @("0.00")
                                                }
                                            }
                     руб.
                                        </div>
                                    </div>
                                }
                            </div>

                            <div class="order-total">Итого: @order.TotalAmount.ToString("N2") руб.</div>

                            <div class="order-actions">
                                @if (order.Status == "Доставлен" || order.Status == "Завершен")
                                {
                                    <button class="review-btn" @onclick="() => WriteReview(order.OrderId)">Оставить отзыв</button>
                                }
                                @if (order.Status == "Доставлен")
                                {
                                    <button class="repeat-order-btn" @onclick="() => RepeatOrder(order.OrderId)">Повторить заказ</button>
                                }
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="empty-state">
                        <p>У вас пока нет завершенных заказов</p>
                        <button class="continue-shopping-btn" @onclick="ContinueShopping">Продолжить покупки</button>
                    </div>
                }
            </div>
        }
    </div>
}

@code {
    private List<OrderWithStatus> currentOrders = new();
    private List<OrderWithStatus> completedOrders = new();
    private bool isLoading = true;
    private bool hasError = false;
    private string activeTab = "current";

    protected override async System.Threading.Tasks.Task OnInitializedAsync()
    {
        await LoadAllData();
    }

    private async System.Threading.Tasks.Task LoadAllData()
    {
        try
        {
            isLoading = true;
            hasError = false;
            StateHasChanged();

            // Проверяем авторизацию
            if (UserService.currentUser == null || string.IsNullOrEmpty(UserService.currentUser.Email))
            {
                NavigationManager.NavigateTo("/");
                return;
            }

            // Загружаем заказы
            currentOrders = await OrderService.GetCurrentOrdersAsync(UserService.currentUser.Email);
            completedOrders = await OrderService.GetCompletedOrdersAsync(UserService.currentUser.Email);
        }
        catch (Exception ex)
        {
            hasError = true;
            Console.WriteLine($"Ошибка загрузки: {ex.Message}");
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private async System.Threading.Tasks.Task SwitchTab(string tab)
    {
        activeTab = tab;
        StateHasChanged();
        await System.Threading.Tasks.Task.CompletedTask;
    }

    private async System.Threading.Tasks.Task CancelOrder(int orderId)
    {
        var confirmed = await JSRuntime.InvokeAsync<bool>("confirm", "Вы уверены, что хотите отменить этот заказ?");
        if (confirmed)
        {
            try
            {
                var success = await OrderService.CancelOrderAsync(orderId);
                if (success)
                {
                    await JSRuntime.InvokeVoidAsync("alert", "Заказ успешно отменен");
                    await LoadAllData();
                }
                else
                {
                    await JSRuntime.InvokeVoidAsync("alert", "Ошибка при отмене заказа");
                }
            }
            catch (Exception ex)
            {
                await JSRuntime.InvokeVoidAsync("alert", $"Ошибка отмены заказа: {ex.Message}");
            }
        }
    }

    private async System.Threading.Tasks.Task WriteReview(int orderId)
    {
        NavigationManager.NavigateTo($"/review/{orderId}");
        await System.Threading.Tasks.Task.CompletedTask;
    }

    private async System.Threading.Tasks.Task RepeatOrder(int orderId)
    {
        var order = completedOrders.FirstOrDefault(o => o.OrderId == orderId);
        if (order != null && UserService.currentUser != null)
        {
            try
            {
                // Создаем список CartItem для добавления в корзину
                var cartItems = new List<CartItem>();

                for (int i = 0; i < order.Products.Count; i++)
                {
                    var cartItem = new CartItem
                    {
                        ByerId = UserService.currentUser.Email,
                        PresentCardId = order.Products[i].Id,
                        Quantity = order.Quantities[i]
                    };
                    cartItems.Add(cartItem);
                }

                // Получаем текущую корзину пользователя из базы данных
                var existingCartItems = await ProductService.GetUserCartItemsAsync(UserService.currentUser.Email);

                // Объединяем с существующими товарами
                foreach (var newItem in cartItems)
                {
                    var existingItem = existingCartItems.FirstOrDefault(ci => ci.PresentCardId == newItem.PresentCardId);
                    if (existingItem != null)
                    {
                        // Обновляем количество существующего товара
                        await ProductService.UpdateCartItemQuantityAsync(
                            existingItem.CartItemId,
                            existingItem.Quantity + newItem.Quantity);
                    }
                    else
                    {
                        // Добавляем новый товар
                        await ProductService.AddToCartAsync(
                            UserService.currentUser.Email,
                            newItem.PresentCardId,
                            newItem.Quantity);
                    }
                }

                await JSRuntime.InvokeVoidAsync("alert", "Товары добавлены в корзину");
                NavigationManager.NavigateTo("/cart");
            }
            catch (Exception ex)
            {
                await JSRuntime.InvokeVoidAsync("alert", $"Ошибка при повторении заказа: {ex.Message}");
            }
        }
    }

    private async System.Threading.Tasks.Task RetryLoading()
    {
        await LoadAllData();
    }

    private async System.Threading.Tasks.Task Logout()
    {
        UserService.Logout();
        await JSRuntime.InvokeVoidAsync("localStorage.removeItem", "userEmail");
        NavigationManager.NavigateTo("/");
    }

    private void ContinueShopping()
    {
        NavigationManager.NavigateTo("/");
    }

    private string GetStatusClass(string status)
    {
        return status switch
        {
            "Создан" => "created",
            "Подтвержден" => "confirmed",
            "Оплачен" => "paid",
            "Собран" => "collected",
            "Отправлен" => "shipped",
            "В доставке" => "delivering",
            "Доставлен" => "delivered",
            "Завершен" => "completed",
            "Отменен" => "cancelled",
            "Возврат" => "returned",
            _ => "unknown"
        };
    }
}